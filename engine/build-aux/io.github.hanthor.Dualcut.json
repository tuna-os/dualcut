{
  "//": "Flatpak manifest \u2014 the deliverable. Built in CI by .github/workflows/flatpak.yml,",
  "//2": "which generates cargo-sources.json with flatpak-cargo-generator before building.",
  "//3": "Scripting ships in the bundle: rusty_v8's static lib is provided offline via RUSTY_V8_ARCHIVE.",
  "id": "io.github.hanthor.Dualcut",
  "runtime": "org.gnome.Platform",
  "runtime-version": "50",
  "sdk": "org.gnome.Sdk",
  "sdk-extensions": [
    "org.freedesktop.Sdk.Extension.rust-stable"
  ],
  "command": "dualcut",
  "finish-args": [
    "--socket=wayland",
    "--socket=fallback-x11",
    "--socket=pulseaudio",
    "--device=dri",
    "--share=ipc",
    "--env=GST_PLUGIN_PATH=/app/lib/gstreamer-1.0",
    "--share=network",
    "--filesystem=home"
  ],
  "build-options": {
    "append-path": "/usr/lib/sdk/rust-stable/bin",
    "env": {
      "CARGO_HOME": "/run/build/dualcut/cargo"
    }
  },
  "modules": [
    {
      "name": "gst-editing-services",
      "buildsystem": "meson",
      "config-opts": [
        "-Ddoc=disabled",
        "-Dtests=disabled",
        "-Dexamples=disabled",
        "-Dintrospection=disabled",
        "-Dvalidate=disabled"
      ],
      "sources": [
        {
          "type": "archive",
          "url": "https://gstreamer.freedesktop.org/src/gst-editing-services/gst-editing-services-1.24.2.tar.xz",
          "sha256": "7201778ea5d937440c53d7439dd12aa5ac6840688af1f0499852275074b99073"
        }
      ]
    },
    {
      "name": "x264",
      "buildsystem": "simple",
      "build-commands": [
        "./configure --prefix=/app --enable-shared --disable-cli --enable-pic",
        "make -j $FLATPAK_BUILDER_N_JOBS",
        "make install"
      ],
      "sources": [
        {
          "type": "git",
          "url": "https://code.videolan.org/videolan/x264.git",
          "commit": "b35605ace3ddf7c1a5d67a2eb553f034aef41d55"
        }
      ]
    },
    {
      "name": "gst-plugins-ugly",
      "buildsystem": "meson",
      "config-opts": [
        "-Ddoc=disabled",
        "-Dgpl=enabled",
        "-Dauto_features=disabled",
        "-Dx264=enabled"
      ],
      "sources": [
        {
          "type": "archive",
          "url": "https://gstreamer.freedesktop.org/src/gst-plugins-ugly/gst-plugins-ugly-1.26.10.tar.xz",
          "sha256": "b2c648ef62cbf03cdc215f55dca01e2e8372983d8c88de3fa03671ddf08d7d14"
        }
      ]
    },
    {
      "name": "x265",
      "buildsystem": "cmake-ninja",
      "subdir": "source",
      "config-opts": [
        "-DCMAKE_BUILD_TYPE=Release",
        "-DENABLE_CLI=OFF",
        "-DCMAKE_POLICY_VERSION_MINIMUM=3.5"
      ],
      "sources": [
        {
          "type": "archive",
          "url": "https://bitbucket.org/multicoreware/x265_git/downloads/x265_4.1.tar.gz",
          "sha256": "a31699c6a89806b74b0151e5e6a7df65de4b49050482fe5ebf8a4379d7af8f29"
        },
        {
          "type": "shell",
          "commands": [
            "sed -i '/cmake_policy(SET CMP0025 OLD)/d;/cmake_policy(SET CMP0054 OLD)/d' source/CMakeLists.txt"
          ]
        }
      ]
    },
    {
      "name": "svt-av1",
      "buildsystem": "cmake-ninja",
      "config-opts": [
        "-DCMAKE_BUILD_TYPE=Release",
        "-DBUILD_APPS=OFF",
        "-DBUILD_DEC=OFF",
        "-DCMAKE_POLICY_VERSION_MINIMUM=3.5",
        "-DUSE_CPUINFO=OFF"
      ],
      "sources": [
        {
          "type": "archive",
          "url": "https://gitlab.com/AOMediaCodec/SVT-AV1/-/archive/v3.0.2/SVT-AV1-v3.0.2.tar.gz",
          "sha256": "5af7f4376aa00a4dee32df04be1cdd1983c9940bcc019ee6b29bb8a216bae2f8"
        }
      ]
    },
    {
      "name": "gst-plugins-bad-codecs",
      "buildsystem": "meson",
      "config-opts": [
        "-Ddoc=disabled",
        "-Dgpl=enabled",
        "-Dauto_features=disabled",
        "-Dx265=enabled",
        "-Dsvtav1=enabled"
      ],
      "sources": [
        {
          "type": "archive",
          "url": "https://gstreamer.freedesktop.org/src/gst-plugins-bad/gst-plugins-bad-1.26.10.tar.xz",
          "sha256": "fec973dff512b507d9dcb5a828e04e061e52188f4d5989e953aed6a41beda437"
        }
      ]
    },
    {
      "name": "gst-libav",
      "buildsystem": "meson",
      "config-opts": [
        "-Ddoc=disabled"
      ],
      "sources": [
        {
          "type": "archive",
          "url": "https://gstreamer.freedesktop.org/src/gst-libav/gst-libav-1.26.10.tar.xz",
          "sha256": "c8c2fd29cc063a6d26c314cd1a0a3a3060c8a029981b9520fab52c4206d11611"
        }
      ]
    },
    {
      "name": "dualcut",
      "buildsystem": "simple",
      "build-commands": [
        "cargo --offline build --release --features preview,vector,scripting --bin preview",
        "install -Dm755 target/release/preview /app/bin/dualcut",
        "install -Dm644 build-aux/io.github.hanthor.Dualcut.desktop /app/share/applications/io.github.hanthor.Dualcut.desktop",
        "install -Dm644 build-aux/io.github.hanthor.Dualcut.metainfo.xml /app/share/metainfo/io.github.hanthor.Dualcut.metainfo.xml",
        "install -Dm644 build-aux/io.github.hanthor.Dualcut.svg /app/share/icons/hicolor/scalable/apps/io.github.hanthor.Dualcut.svg",
        "install -Dm644 skills-src/dualcut/SKILL.md /app/share/dualcut/skills/dualcut/SKILL.md"
      ],
      "sources": [
        {
          "type": "dir",
          "path": ".."
        },
        {
          "type": "dir",
          "path": "../../skills",
          "dest": "skills-src"
        },
        {
          "type": "file",
          "url": "https://github.com/denoland/rusty_v8/releases/download/v137.3.0/librusty_v8_release_x86_64-unknown-linux-gnu.a.gz",
          "sha256": "a2681fde53018abd3366018f132617dd598002df78f156c7bc6d2ff608b56567",
          "only-arches": [
            "x86_64"
          ]
        },
        "cargo-sources.json"
      ],
      "build-options": {
        "env": {
          "RUSTY_V8_ARCHIVE": "/run/build/dualcut/librusty_v8_release_x86_64-unknown-linux-gnu.a.gz"
        }
      }
    }
  ],
  "add-extensions": {
    "org.freedesktop.Platform.ffmpeg-full": {
      "version": "25.08",
      "directory": "lib/ffmpeg",
      "add-ld-path": ".",
      "no-autodownload": false,
      "autodelete": false
    }
  },
  "cleanup-commands": [
    "mkdir -p /app/lib/ffmpeg"
  ]
}