{
  "//": "Flatpak manifest \u2014 the deliverable. Built in CI by .github/workflows/flatpak.yml,",
  "//2": "which generates cargo-sources.json with flatpak-cargo-generator before building.",
  "//3": "Scripting ships in the bundle: rusty_v8's static lib is provided offline via RUSTY_V8_ARCHIVE.",
  "id": "io.github.hanthor.Dualcut",
  "runtime": "org.gnome.Platform",
  "runtime-version": "50",
  "sdk": "org.gnome.Sdk",
  "sdk-extensions": [
    "org.freedesktop.Sdk.Extension.rust-stable"
  ],
  "command": "dualcut",
  "finish-args": [
    "--socket=wayland",
    "--socket=fallback-x11",
    "--socket=pulseaudio",
    "--device=dri",
    "--share=ipc",
    "--env=GST_PLUGIN_PATH=/app/lib/gstreamer-1.0",
    "--share=network",
    "--filesystem=home"
  ],
  "build-options": {
    "append-path": "/usr/lib/sdk/rust-stable/bin",
    "env": {
      "CARGO_HOME": "/run/build/dualcut/cargo"
    }
  },
  "modules": [
    {
      "name": "gst-editing-services",
      "buildsystem": "meson",
      "config-opts": [
        "-Ddoc=disabled",
        "-Dtests=disabled",
        "-Dexamples=disabled",
        "-Dintrospection=disabled",
        "-Dvalidate=disabled"
      ],
      "sources": [
        {
          "type": "archive",
          "url": "https://gstreamer.freedesktop.org/src/gst-editing-services/gst-editing-services-1.24.2.tar.xz",
          "sha256": "7201778ea5d937440c53d7439dd12aa5ac6840688af1f0499852275074b99073"
        }
      ]
    },
    {
      "name": "dualcut",
      "buildsystem": "simple",
      "build-commands": [
        "cargo --offline build --release --features preview,vector,scripting --bin preview",
        "install -Dm755 target/release/preview /app/bin/dualcut",
        "install -Dm644 build-aux/io.github.hanthor.Dualcut.desktop /app/share/applications/io.github.hanthor.Dualcut.desktop",
        "install -Dm644 build-aux/io.github.hanthor.Dualcut.metainfo.xml /app/share/metainfo/io.github.hanthor.Dualcut.metainfo.xml",
        "install -Dm644 build-aux/io.github.hanthor.Dualcut.svg /app/share/icons/hicolor/scalable/apps/io.github.hanthor.Dualcut.svg",
        "install -Dm644 skills-src/dualcut/SKILL.md /app/share/dualcut/skills/dualcut/SKILL.md"
      ],
      "sources": [
        {
          "type": "dir",
          "path": ".."
        },
        {
          "type": "dir",
          "path": "../../skills",
          "dest": "skills-src"
        },
        {
          "type": "file",
          "url": "https://github.com/denoland/rusty_v8/releases/download/v137.3.0/librusty_v8_release_x86_64-unknown-linux-gnu.a.gz",
          "sha256": "a2681fde53018abd3366018f132617dd598002df78f156c7bc6d2ff608b56567",
          "only-arches": [
            "x86_64"
          ]
        },
        "cargo-sources.json"
      ],
      "build-options": {
        "env": {
          "RUSTY_V8_ARCHIVE": "/run/build/dualcut/librusty_v8_release_x86_64-unknown-linux-gnu.a.gz"
        }
      }
    }
  ]
}