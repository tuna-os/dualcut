{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/tuna-os/dualcut/blob/main/engine/schema/dualcut.schema.json",
  "title": "dualcut project document",
  "type": "object",
  "required": [
    "meta",
    "scenes"
  ],
  "properties": {
    "meta": {
      "type": "object",
      "required": [
        "title",
        "width",
        "height",
        "fps"
      ],
      "properties": {
        "title": {
          "type": "string"
        },
        "width": {
          "type": "integer",
          "exclusiveMinimum": 0
        },
        "height": {
          "type": "integer",
          "exclusiveMinimum": 0
        },
        "fps": {
          "type": "integer",
          "exclusiveMinimum": 0
        }
      }
    },
    "defs": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": [
          "layers"
        ],
        "properties": {
          "params": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "layers": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/clip"
            }
          }
        }
      }
    },
    "scenes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "duration"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "name": {
            "type": "string"
          },
          "duration": {
            "type": "number",
            "exclusiveMinimum": 0
          },
          "transition": {
            "type": "object",
            "required": [
              "duration"
            ],
            "properties": {
              "kind": {
                "const": "crossfade"
              },
              "duration": {
                "type": "number",
                "exclusiveMinimum": 0
              }
            }
          },
          "layers": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/clip"
            }
          }
        }
      }
    },
    "overlays": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "name": {
            "type": "string"
          },
          "clips": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/clip"
            }
          }
        }
      }
    },
    "library": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "transform": {
      "type": "object",
      "properties": {
        "x": {
          "type": "number"
        },
        "y": {
          "type": "number"
        },
        "width": {
          "type": "number",
          "minimum": 0
        },
        "height": {
          "type": "number",
          "minimum": 0
        },
        "opacity": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "anim": {
      "type": "object",
      "required": [
        "property"
      ],
      "properties": {
        "property": {
          "enum": [
            "x",
            "y",
            "width",
            "height",
            "opacity",
            "volume"
          ]
        },
        "from": {
          "type": "number"
        },
        "to": {
          "type": "number"
        },
        "start": {
          "type": "number",
          "minimum": 0
        },
        "end": {
          "type": "number",
          "minimum": 0
        },
        "easing": {
          "enum": [
            "linear",
            "easeIn",
            "easeOut",
            "easeInOut"
          ]
        },
        "keyframes": {
          "type": "array",
          "minItems": 2,
          "items": {
            "type": "object",
            "required": [
              "t",
              "value"
            ],
            "properties": {
              "t": {
                "type": "number",
                "minimum": 0
              },
              "value": {
                "type": "number"
              },
              "easing": {
                "enum": [
                  "linear",
                  "easeIn",
                  "easeOut",
                  "easeInOut"
                ]
              }
            }
          }
        }
      }
    },
    "clip": {
      "type": "object",
      "required": [
        "id",
        "type"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "start": {
          "type": "number",
          "minimum": 0
        },
        "duration": {
          "type": "number",
          "minimum": 0
        },
        "transform": {
          "$ref": "#/$defs/transform"
        },
        "animations": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/anim"
          }
        },
        "type": {
          "enum": [
            "text",
            "video",
            "audio",
            "image",
            "shape",
            "compref",
            "test"
          ]
        },
        "text": {
          "type": "string"
        },
        "font": {
          "type": "string"
        },
        "color": {
          "type": "string",
          "pattern": "^#[0-9a-fA-F]{6}([0-9a-fA-F]{2})?$"
        },
        "src": {
          "type": "string"
        },
        "offset": {
          "type": "number",
          "minimum": 0
        },
        "volume": {
          "type": "number",
          "minimum": 0
        },
        "shape": {
          "enum": [
            "rect",
            "circle",
            "ellipse",
            "star",
            "polygon",
            "line",
            "arrow"
          ]
        },
        "fill": {
          "type": "string"
        },
        "ref": {
          "type": "string"
        },
        "args": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "effects": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/effect"
          }
        },
        "align": {
          "enum": [
            "left",
            "center",
            "right"
          ]
        },
        "outline": {
          "type": "string"
        },
        "shadow": {
          "type": "boolean"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "type": {
                "const": "text"
              }
            }
          },
          "then": {
            "required": [
              "text"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "enum": [
                  "video",
                  "audio",
                  "image"
                ]
              }
            }
          },
          "then": {
            "required": [
              "src"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "shape"
              }
            }
          },
          "then": {
            "required": [
              "shape"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "compref"
              }
            }
          },
          "then": {
            "required": [
              "ref"
            ]
          }
        }
      ]
    },
    "effect": {
      "type": "object",
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "enum": [
            "blur",
            "color",
            "chromakey",
            "crop",
            "eq",
            "compressor",
            "denoise",
            "mask"
          ]
        },
        "amount": {
          "type": "number",
          "minimum": 0,
          "maximum": 50
        },
        "brightness": {
          "type": "number",
          "minimum": -1,
          "maximum": 1
        },
        "contrast": {
          "type": "number",
          "minimum": 0,
          "maximum": 2
        },
        "saturation": {
          "type": "number",
          "minimum": 0,
          "maximum": 2
        },
        "hue": {
          "type": "number",
          "minimum": -1,
          "maximum": 1
        },
        "color": {
          "type": "string"
        },
        "angle": {
          "type": "number",
          "minimum": 1,
          "maximum": 90
        },
        "noise": {
          "type": "number",
          "minimum": 0,
          "maximum": 64
        },
        "left": {
          "type": "integer",
          "minimum": 0
        },
        "right": {
          "type": "integer",
          "minimum": 0
        },
        "top": {
          "type": "integer",
          "minimum": 0
        },
        "bottom": {
          "type": "integer",
          "minimum": 0
        },
        "low": {
          "type": "number",
          "minimum": -24,
          "maximum": 12
        },
        "mid": {
          "type": "number",
          "minimum": -24,
          "maximum": 12
        },
        "high": {
          "type": "number",
          "minimum": -24,
          "maximum": 12
        },
        "threshold": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "ratio": {
          "type": "number",
          "minimum": 1,
          "maximum": 4
        },
        "level": {
          "type": "integer",
          "minimum": 0,
          "maximum": 3
        },
        "shape": {
          "enum": [
            "rect",
            "circle",
            "ellipse",
            "star",
            "polygon",
            "line",
            "arrow"
          ]
        },
        "feather": {
          "type": "number",
          "minimum": 0,
          "maximum": 50
        },
        "invert": {
          "type": "boolean"
        }
      }
    }
  }
}